{"metadata":{"cellCounter":8},"cells":[{"kind":1,"language":"markdown","metadata":{"slug":"cell-1","slugIsAuto":true},"value":"## Notebook\n\nThis notebook demonstrates the SPARQL query capabilities of Mentor."},{"kind":2,"language":"sparql","metadata":{"slug":"cell-2","slugIsAuto":true},"value":"PREFIX owl: <http://www.w3.org/2002/07/owl#>\n\nSELECT DISTINCT ?s \nFROM <workspace:///src/rdf/tests/vocabularies/gist.ttl>\nWHERE {\n    ?s a owl:Class .\n\n    FILTER(ISURI(?s))\n}\nLIMIT 100"},{"kind":2,"language":"sparql","metadata":{"slug":"cell-3","slugIsAuto":true},"value":"ASK WHERE { GRAPH ?g { ?s ?p ?o . } }"},{"kind":2,"language":"sparql","metadata":{"slug":"cell-4","slugIsAuto":true},"value":"PREFIX owl: <http://www.w3.org/2002/07/owl#>\n\nDESCRIBE owl:Thing"},{"kind":2,"language":"turtle","metadata":{"slug":"cell-5","slugIsAuto":true},"value":"@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix skos: <http://www.w3.org/2004/02/skos/core#> .\n@prefix : <file:error-missing-semicolon.ttl#> .\n\n# This is a test file with a comment.\n:Test a rdfs:Class ;\n    skos:prefLabel \"Test\"@en ."},{"kind":2,"language":"turtle","metadata":{"slug":"cell-6","slugIsAuto":true},"value":"@prefix : <workspace:///src/rdf/tests/queries/notebook.mnb#cell-6?id=> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix skos: <http://www.w3.org/2004/02/skos/core#> .\n\n:Test2 a rdfs:Class ;\n    skos:prefLabel \"Test 2\"@en ."},{"kind":2,"language":"turtle","metadata":{"slug":"cell-7","slugIsAuto":true},"value":"@prefix : <workspace:///src/rdf/tests/queries/notebook.mnb#cell-7?id=> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n\n:Test a rdfs:Class ;\n    rdfs:label \"Test 1\"@en ."},{"kind":2,"language":"sparql","metadata":{"slug":"cell-8","slugIsAuto":true},"value":"SELECT *\nFROM <workspace:///src/rdf/tests/queries/notebook.mnb#cell-7>\nWHERE {\n    ?s ?p ?o .\n}"}]}